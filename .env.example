# VoiceOS Environment Configuration
# Copy to .env and adjust values: cp .env.example .env

# Core
VOICEOS_ENV=development
LOG_LEVEL=INFO
VOICEOS_WORKSPACE=./workspace

# LLM (local Ollama or GGUF)
LLM_ENDPOINT=http://localhost:11434/api/generate
LLM_MODEL=mistral
MODELS_DIRECTORY=./models
MAX_RAM_THRESHOLD=12

# Speech
WHISPER_MODEL=base
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_OUTPUT_PATH=./output/response.wav
MICROPHONE_DEVICE=default

# Optional cloud API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Security
PERMISSION_LEVEL=medium
SANDBOX_ENABLED=true

# Distributed execution
REDIS_URL=redis://localhost:6379/0
EXECUTION_MODE=auto

# Unified sandbox (code runs in Docker workers when Redis + workers are up)
VOICEOS_SANDBOX_PREFER_DOCKER=true
VOICEOS_CODE_EXEC_TIMEOUT=60
# VOICEOS_SANDBOX_LOCAL=true   # force host subprocess even when workers are up

# Prebuilt worker image (optional — omit to build from Dockerfile.worker)
# VOICEOS_WORKER_IMAGE=ghcr.io/your-org/voiceos-worker:latest

# Host bridge (always-on OS automation IPC)
# auto | bridge | local
VOICEOS_BRIDGE_MODE=auto
VOICEOS_BRIDGE_HOST=127.0.0.1
VOICEOS_BRIDGE_PORT=18765
# VOICEOS_BRIDGE_URL=http://127.0.0.1:18765
# VOICEOS_BRIDGE_TOKEN=your-secret-token

# Session shell (Phase D — wake word / push-to-talk)
# VOICEOS_SHELL_ENABLED=true
# VOICEOS_SHELL_INPUT_MODE=wake_word
# always_on | wake_word | push_to_talk
# VOICEOS_WAKE_PHRASES=hey voiceos,voice os
# VOICEOS_PTT_KEY=space

# Policy & trust (Phase E)
# personal | work | unattended
VOICEOS_POLICY_PROFILE=personal

# Web UI
WEB_PORT=8000
